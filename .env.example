# ─────────────────────────────────────────────
# RID Radar — Environment Variables Template
# ─────────────────────────────────────────────

# Brand
APP_NAME=RID Radar
RADAR_BRAND=rid

# Database
DATABASE_URL="postgresql://radar:radar_dev@localhost:5433/rid_radar"

# LLM (optional — heuristic classifier used as fallback)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Search API keys
SERPAPI_KEY=
BING_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# X (Twitter) API v2
X_BEARER_TOKEN=

# Scheduler — disabled by default, use manual Run buttons
DISABLE_SCHEDULER=true
REDDIT_INTERVAL_MINUTES=60
RSS_INTERVAL_MINUTES=60
SEARCH_INTERVAL_HOURS=6

# Score thresholds (RID tuned — lower than BK Radar)
SCORE_THRESHOLD=55
MIN_STORE_SCORE=35
MAX_HISTORY_DAYS=183

# API port
API_PORT=3001

# Auth — comma-separated email:bcrypt-hash pairs
# Generate hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('yourpassword',10))"
AUTH_USERS=

# Web
PUBLIC_WEB_BASE_URL=http://localhost:3000
