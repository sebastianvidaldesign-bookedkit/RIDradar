# Database
DATABASE_URL="postgresql://radar:radar_dev@localhost:5432/bookedkit_radar"

# LLM Configuration (optional — heuristic classifier used as fallback)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Search API keys (optional — collector disabled if no keys)
SERPAPI_KEY=
BING_KEY=

# Google Custom Search (free 100 queries/day — recommended)
# 1. Create API key: https://console.developers.google.com/apis/credentials
# 2. Create search engine: https://programmablesearchengine.google.com/
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# X (Twitter) API v2
X_BEARER_TOKEN=

# Collector intervals
REDDIT_INTERVAL_MINUTES=60
RSS_INTERVAL_MINUTES=60
SEARCH_INTERVAL_HOURS=6

# Score threshold for generating reply drafts & digest
SCORE_THRESHOLD=70

# Min score to store a mention at all (below this = discarded)
MIN_STORE_SCORE=40

# Discard posts older than this many days (default 183 = ~6 months)
MAX_HISTORY_DAYS=183

# API port
API_PORT=3001

# Email digest
EMAIL_PROVIDER=auto
DIGEST_TO_EMAIL=you@example.com
DIGEST_FROM_EMAIL=radar@bookedkit.com
DIGEST_TIMEZONE=America/New_York
PUBLIC_WEB_BASE_URL=http://localhost:3000

# SendGrid (optional)
SENDGRID_API_KEY=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
